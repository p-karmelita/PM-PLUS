{
  "name": "pm-plus-api",
  "version": "1.0.0",
  "description": "Agent orchestration API with Band.ai patterns",
  "main": "api/index.ts",
  "scripts": {
    "dev": "tsx watch api/index.ts",
    "build": "tsc",
    "build:dashboard": "cd dashboard && npm install && npm run build",
    "build:all": "npm run build:dashboard && npm run build",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
