# ──────────────────────────────────────────────────────────────────────────
# PM PLUS — environment template
# Copy to `.env` and fill in real values:  cp .env.example .env
# (the offline dashboard demo — POST /demo/simulate — needs NONE of these;
#  they are only required for the real Band.ai agent pipeline.)
# ──────────────────────────────────────────────────────────────────────────

# ── API server (api/) ──────────────────────────────────────────────────────
PORT=3000
# Optional API auth. When set, API routes require X-API-Key, Bearer token, or ?apiKey=...
API_AUTH_TOKEN=

# ── Band.ai platform ───────────────────────────────────────────────────────
BAND_REST_URL=https://app.band.ai/api/v1
BAND_WS_URL=wss://app.band.ai/api/v1/socket/websocket
# Default key used by GET /demo/start-checkin when no X-API-Key header is sent
BAND_API_KEY=your_default_band_api_key

# ── Band rooms (chat IDs) ──────────────────────────────────────────────────
OPS_ROOM_ID=your_ops_room_id              # where check-ins are posted / approvals bridged back
PM_ALERTS_ROOM_ID=your_pm_alerts_room_id  # where Risk Analyzer posts risk flags
REPORTS_ROOM_ID=your_reports_room_id       # where the Reporter posts weekly summaries

# ── Agent identities + keys (src/ Python agents) ───────────────────────────
# Risk Analyzer — used by risk.py (PM alert post) and demo /trigger-real (mentions)
RISK_ANALYZER_AGENT_ID=your_risk_analyzer_agent_id
RISK_ANALYZER_API_KEY=your_risk_analyzer_api_key
# Reporter — also the posting key for the approval bridge + demo /trigger-real
REPORTER_API_KEY=your_reporter_api_key
# Resource Balancer
RESOURCE_BALANCER_AGENT_ID=your_resource_balancer_agent_id
RESOURCE_BALANCER_API_KEY=your_resource_balancer_api_key

# ── Agent identities + keys (api/ orchestrator: bandai.service.ts) ─────────
COLLECTOR_AGENT_ID=your_collector_agent_id
COLLECTOR_API_KEY=your_collector_api_key
DRAFTER_AGENT_ID=your_drafter_agent_id
DRAFTER_API_KEY=your_drafter_api_key
REVIEWER_AGENT_ID=your_reviewer_agent_id
REVIEWER_API_KEY=your_reviewer_api_key

# ── LLM provider (src/core/llm.py) ─────────────────────────────────────────
LLM_PROVIDER=aiml                 # 'aiml' (primary) or 'featherless' (fallback)
AIML_API_KEY=your_aiml_api_key
AIML_MODEL=gpt-4o
FEATHERLESS_API_KEY=your_featherless_api_key
FEATHERLESS_MODEL=your_featherless_model

# ── Cross-service ──────────────────────────────────────────────────────────
STATE_STORE_URL=http://localhost:3000   # base URL the Python agents call for state/reporter endpoints

# ── Backbone persistence / scheduler / integrations ───────────────────────
BACKBONE_STORE_FILE=./data/backbone-store.json
SCHEDULER_ENABLED=false
DAILY_CHECKIN_TIME=09:00
WEEKLY_REPORT_DAY=friday
WEEKLY_REPORT_TIME=16:00
SLACK_WEBHOOK_URL=
MS_TEAMS_WEBHOOK_URL=
